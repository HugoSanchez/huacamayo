{
  "name": "verso-sidecar",
  "version": "0.1.0",
  "description": "Thin local Hermes sidecar for the verso macOS app",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit",
    "serve": "tsx src/http/server.ts",
    "memoryd": "tsx src/memoryd/main.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@composio/core": "^0.9.1",
    "@huggingface/transformers": "^4.2.0",
    "dotenv": "^16.6.1",
    "pg": "^8.22.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.4"
  }
}
