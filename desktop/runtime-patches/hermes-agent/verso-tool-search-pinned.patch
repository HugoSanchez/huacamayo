+def _parse_pinned(value: Any) -> Tuple[str, ...]:
+    """Parse ``tools.tool_search.pinned`` into a validated name tuple.
+
+    Malformed entries are dropped rather than raising, matching the rest of
+    the config parsing: a typo in user config must not break the agent.
+    Bridge tool names can never be pinned, and the list is capped so a
+    pathological config cannot defeat deferral wholesale.
+    """
+    if not isinstance(value, (list, tuple)):
+        return ()
+    names: List[str] = []
+    seen: set[str] = set()
+    for item in value:
+        if not isinstance(item, str):
+            continue
+        name = item.strip()
+        if not name or name in seen or name in BRIDGE_TOOL_NAMES:
+            continue
+        seen.add(name)
+        names.append(name)
+        if len(names) >= 100:
+            break
+    return tuple(names)
 
 
