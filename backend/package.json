{
  "name": "verso-backend",
  "version": "0.1.0",
  "description": "Remote API backend for managed verso users",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "serve": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:smoke": "tsx scripts/smoke-db.ts",
    "issue-test-session": "tsx scripts/issue-test-session.ts"
  },
  "dependencies": {
    "@composio/core": "^0.8.0",
    "@fastify/cors": "^11.1.0",
    "@neondatabase/serverless": "^1.0.1",
    "@privy-io/node": "^0.17.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.6.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  }
}
