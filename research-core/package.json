{
  "name": "research-core",
  "version": "0.1.0",
  "description": "Local research sidecar: indexing, retrieval, knowledge graph, and MCP server for Vervo",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "serve": "bun run src/http/server.ts",
    "test": "vitest run",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "gray-matter": "^4.0.3",
    "marked": "^18.0.0",
    "node-llama-cpp": "^3.18.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.4"
  }
}
